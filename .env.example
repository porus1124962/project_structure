# ──────────────────────────────────────────────────────────────────────────────
# .env.example — copy this file to .env and fill in your values.
# .env is listed in .gitignore and must NEVER be committed.
# ──────────────────────────────────────────────────────────────────────────────

# Build environment: "dev" or "production"
# Pass at build / run time via --dart-define=ENVIRONMENT=production
ENVIRONMENT=dev

# ── API ───────────────────────────────────────────────────────────────────────
# Override the URLs defined in lib/services/Network/Url.dart if needed.
# These are for documentation purposes — the app reads from Url.dart directly.
DEV_API_URL=https://dev-api.example.com/api/
PROD_API_URL=https://api.example.com/api/

# ── Firebase (optional) ───────────────────────────────────────────────────────
# Generated by `flutterfire configure`. See lib/config.dart for instructions.
# GOOGLE_SERVICES_JSON=...  (use the file, not an env var)

